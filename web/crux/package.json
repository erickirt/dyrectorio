{
  "name": "crux",
  "version": "0.15.4",
  "description": "Open-source delivery platform that helps developers to deliver applications efficiently by simplifying software releases and operations in any environment.",
  "author": "dyrector.io",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyrector-io/dyrectorio.git"
  },
  "bugs": {
    "url": "https://github.com/dyrector-io/dyrectorio/issues"
  },
  "homepage": "https://github.com/dyrector-io/dyrectorio#readme",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start --debug --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "encrypt:generate": "node dist/main encrypt generate",
    "encrypt:rotate": "node dist/main encrypt rotate",
    "grpc:debug": "GRPC_VERBOSITY=DEBUG GRPC_TRACE=all npm start",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" && prettier --check \"src/**/*.ts\"",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:cov": "jest --detectOpenHandles --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:ci": "jest --config ./jest.config.js --collectCoverage --coverageDirectory=\"./coverage\" --ci --reporters=default --reporters=jest-junit --watchAll=false",
    "ts-node": "ts-node --compiler-options { \"module\": \"CommonJS\"}",
    "prisma:gen": "prisma generate",
    "prisma:migrate": "prisma migrate deploy"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/common": "^11.1.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.11",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.11",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/platform-ws": "^11.1.11",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/websockets": "^11.1.11",
    "@ory/kratos-client": "^1.2.1",
    "@prisma/client": "5.1.0",
    "@types/google-protobuf": "^3.15.6",
    "@types/semver": "^7.5.0",
    "@types/ws": "^8.5.5",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.13.2",
    "cache-manager": "^7.2.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.2.3",
    "google-auth-library": "^9.0.0",
    "google-protobuf": "^3.21.2",
    "handlebars": "^4.7.8",
    "nestjs-pino": "^4.5.0",
    "nodemailer": "^7.0.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.2",
    "pino-http": "^11.0.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "semver": "^7.5.4",
    "uuid": "^9.0.0",
    "ws": "^8.18.3",
    "www-authenticate": "^0.6.3",
    "yup": "^1.2.0"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.11",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.3",
    "@types/node": "^20.4.5",
    "@types/nodemailer": "^6.4.9",
    "@types/passport-jwt": "^3.0.9",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^6.2.1",
    "@typescript-eslint/parser": "^6.2.1",
    "eslint": "^8.46.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^8.9.0",
    "eslint-plugin-import": "^2.28.0",
    "jest": "^29.6.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.0.0",
    "prettier-plugin-organize-imports": "^3.2.3",
    "prisma": "5.1.0",
    "rimraf": "^5.0.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-proto": "^2.10.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
